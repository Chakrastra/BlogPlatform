# ──────────────────────────────────────────────
#  BlogPlatform — Environment Variables
#  Copy this file to .env and fill in values
# ──────────────────────────────────────────────

# Generate a new secret key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-long-random-secret-key-here

# Set to False in production!
DEBUG=False

# Comma-separated list of allowed hosts (your Railway/Heroku domain)
# Example: ALLOWED_HOSTS=myapp.up.railway.app,www.mysite.com
ALLOWED_HOSTS=127.0.0.1,localhost

# Database URL — Railway/Heroku provide this automatically as an env var
# PostgreSQL example: postgresql://user:password@host:5432/dbname
# Leave blank to use SQLite (local dev only)
DATABASE_URL=

# Set to False if not behind HTTPS (e.g. during local dev)
SECURE_SSL_REDIRECT=False
